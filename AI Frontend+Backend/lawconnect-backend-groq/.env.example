# ─────────────────────────────────────────
# LawConnect Backend — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Groq API Key (get for free from https://console.groq.com)
GROQ_API_KEY=gsk_...

# MongoDB Connection String (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lawconnect?retryWrites=true&w=majority

# JWT Secret — use a long random string (e.g. run: openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT expiry
JWT_EXPIRES_IN=7d

# Port (Railway/Render set this automatically)
PORT=3000

# Frontend URL for CORS (your deployed frontend URL)
FRONTEND_URL=http://localhost:5500
