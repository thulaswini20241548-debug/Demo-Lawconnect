# ─────────────────────────────────────────────
#  LawConnect Backend — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Groq API key (required) — get yours at https://console.groq.com
GROQ_API_KEY=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

# Server port (optional, defaults to 3000)
PORT=3000

# Frontend URL for CORS (use * for development, set your real domain in production)
# Examples:
#   Development:   FRONTEND_URL=*
#   Production:    FRONTEND_URL=https://lawconnect.lk
FRONTEND_URL=*

# Environment: development | production
NODE_ENV=development
